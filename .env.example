# =============================================================================
# .env.example — variáveis de ambiente do projeto BankMarketing
# -----------------------------------------------------------------------------
# Copie para `.env` e preencha com valores reais. NUNCA commite o `.env`
# (já está no .gitignore). Este arquivo lista apenas placeholders.
# =============================================================================

# --- Azure OpenAI (assistente LLM da E5) ------------------------------------
# Endpoint do recurso Azure OpenAI, ex.: https://<recurso>.openai.azure.com/
AZURE_OPENAI_ENDPOINT=
# Chave de API do recurso Azure OpenAI (manter em Key Vault em produção)
AZURE_OPENAI_API_KEY=

# --- Azure AI Search (RAG / governança da E4/E8) ----------------------------
# Endpoint do serviço Azure AI Search, ex.: https://<servico>.search.windows.net
AZURE_SEARCH_ENDPOINT=
# Chave de API (admin/query) do Azure AI Search
AZURE_SEARCH_API_KEY=

# --- MLflow (tracking de experimentos da E7) --------------------------------
# URI do tracking server MLflow. Local: file:./mlruns | remoto: https://...
MLFLOW_TRACKING_URI=

# --- Aplicação ---------------------------------------------------------------
# Caminho do arquivo de log estruturado de decisões da API (auditoria)
DECISION_LOG_PATH=
